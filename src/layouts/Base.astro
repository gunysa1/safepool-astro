---
import '../styles/global.css';

interface Props {
  lang: 'he' | 'en';
  title: string;
  description: string;
}
const { lang, title, description } = Astro.props;
const dir = lang === 'he' ? 'rtl' : 'ltr';
const font = lang === 'he' ? 'Assistant:wght@400;600;700;800' : 'Inter:wght@400;600;700;800';
---
<!doctype html>
<html lang={lang} dir={dir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href={`https://fonts.googleapis.com/css2?family=${font}&display=swap`} rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class={`bg-brand-light-blue text-navy scroll-smooth ${lang === 'he' ? 'font-assistant' : 'font-inter'}`}>
    <slot />
  </body>
</html>
