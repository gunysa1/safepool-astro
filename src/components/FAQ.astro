---
interface Props {
  t: {
    heading: string;
    items: { q: string; a: string }[];
  };
}
const { t } = Astro.props;
---
<section id="about" class="py-24 bg-white">
  <div class="max-w-3xl mx-auto px-6">
    <h2 class="text-3xl font-black text-center text-navy mb-12">{t.heading}</h2>
    <div class="space-y-4">
      {t.items.map((item, i) => (
        <div class="border border-blue-100 rounded-2xl overflow-hidden">
          <button
            class="w-full text-start px-6 py-5 font-bold text-navy flex justify-between items-center hover:bg-brand-light-blue transition"
            data-faq={i}
          >
            <span>{item.q}</span>
            <svg class="w-5 h-5 shrink-0 transition-transform" data-faq-icon={i} fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div class="hidden px-6 pb-5 text-slate-600 leading-relaxed" data-faq-body={i}>
            {item.a}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
<script>
  document.querySelectorAll('[data-faq]').forEach(btn => {
    btn.addEventListener('click', () => {
      const i = (btn as HTMLElement).dataset.faq;
      const body = document.querySelector(`[data-faq-body="${i}"]`);
      const icon = document.querySelector(`[data-faq-icon="${i}"]`);
      body?.classList.toggle('hidden');
      icon?.classList.toggle('rotate-180');
    });
  });
</script>
