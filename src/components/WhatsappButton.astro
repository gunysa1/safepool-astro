---
interface Props {
  phone: string;
  lang: 'he' | 'en';
}
const { phone, lang } = Astro.props;
const message = lang === 'he'
  ? 'היי! הגעתי מאתר SafePool ואשמח לשמוע פרטים על שירותי ההצלה 🏊'
  : 'Hi! I found you on the SafePool website and would love to hear more about your lifeguard services 🏊';
const href = `https://wa.me/${phone}?text=${encodeURIComponent(message)}`;
---
<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  class="fixed bottom-8 left-8 z-50 bg-green-500 text-white p-4 rounded-full shadow-2xl hover:bg-green-600 transition-all hover:scale-110"
  aria-label="WhatsApp"
>
  <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24">
    <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.588-5.946C.156 5.148 5.245 0 11.548 0 14.605 0 17.47 1.187 19.627 3.344c2.156 2.156 3.343 5.023 3.343 8.081 0 6.399-5.089 11.547-11.392 11.547-2.003 0-3.971-.523-5.717-1.516L0 .057zM6.146 18.94c1.601.953 3.546 1.456 5.402 1.456 5.253 0 9.527-4.273 9.527-9.526 0-2.545-.994-4.937-2.798-6.741C16.471 4.325 14.083 3.33 11.541 3.33c-5.248 0-9.52 4.273-9.52 9.526 0 1.884.551 3.722 1.593 5.3L2.705 21.23l3.441-.89z"/>
  </svg>
</a>
